---
import LayoutBare from "../layouts/LayoutBare.astro";
import "../styles/v3-sunset.css";
---

<LayoutBare
  title="Imprint · Jetski Lefkada Rentals"
  description="Legal information and company details for Jetski Lefkada Rentals."
>
  <div class="v3 min-h-screen py-32 px-6">
    <div class="mx-auto max-w-3xl">
      <a href="/" class="font-mono text-[10px] uppercase tracking-[0.2em] flex items-center gap-2 mb-12" style="color: var(--v3-flame-500);">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back
      </a>

      <div class="v3-eyebrow mb-6"><span>Legal</span></div>
      <h1 class="v3-display text-5xl lg:text-7xl mb-16"><em>Imprint.</em></h1>

      <div class="space-y-10 text-base leading-relaxed" style="color: rgba(255,230,212,0.8);">
        <section>
          <h2 class="v3-display text-2xl mb-4" style="color: var(--v3-peach-100);">Business Details</h2>
          <p>Jetski Lefkada Rentals<br />
          Nidri Marina<br />
          Nidri, Lefkada 31100<br />
          Greece</p>
        </section>

        <section>
          <h2 class="v3-display text-2xl mb-4" style="color: var(--v3-peach-100);">Owner / Responsible for content</h2>
          <p>Kristina Goldberg</p>
        </section>

        <section>
          <h2 class="v3-display text-2xl mb-4" style="color: var(--v3-peach-100);">Contact</h2>
          <p>
            Phone: <a href="tel:+306955612777" style="color: var(--v3-flame-500);">+30 695 561 2777</a><br />
            Email: <a href="mailto:info@jetski-lefkada-rentals.com" style="color: var(--v3-flame-500);">info@jetski-lefkada-rentals.com</a><br />
            Instagram: <a href="https://instagram.com/jetski__lefkada" target="_blank" rel="noopener" style="color: var(--v3-flame-500);">@jetski__lefkada</a>
          </p>
        </section>

        <section>
          <h2 class="v3-display text-2xl mb-4" style="color: var(--v3-peach-100);">Regulatory Information</h2>
          <p>Licensed by the Port Authority of Lefkada under Greek Maritime Law.<br />
          Operating in compliance with Greek Law 4727/2020 and 4926/2022.</p>
        </section>

        <section>
          <h2 class="v3-display text-2xl mb-4" style="color: var(--v3-peach-100);">Liability Disclaimer</h2>
          <p>Despite careful content control, we assume no liability for the content of external links. The operators of linked pages are solely responsible for their content.</p>
        </section>
      </div>
    </div>
  </div>
</LayoutBare>
