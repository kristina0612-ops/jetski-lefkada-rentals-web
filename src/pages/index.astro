---
import LayoutBare from "../layouts/LayoutBare.astro";
import Navbar2 from "../components/v2/Navbar2.astro";
import Hero2 from "../components/v2/Hero2.astro";
import TrustMarquee2 from "../components/v2/TrustMarquee2.astro";
import Fleet2 from "../components/v2/Fleet2.astro";
import HowItWorks2 from "../components/v2/HowItWorks2.astro";
import Gallery2 from "../components/v2/Gallery2.astro";
// Testimonials2 entfernt 2026-04-18: keine echten Reviews vorhanden,
// Fake-Testimonials wären UWG-/Google-Verstoß. Wieder einbinden, sobald
// ≥3 echte Google-Reviews freigegeben sind.
import Faq2 from "../components/v2/Faq2.astro";
import Booking2 from "../components/v2/Booking2.astro";
import CtaFinal2 from "../components/v2/CtaFinal2.astro";
import Footer2 from "../components/v2/Footer2.astro";
import "../styles/v2-azure.css";
---

<LayoutBare
  title="Jetski Lefkada Rentals · Ride the Ionian like a local"
  description="Rent a Sea-Doo jetski on Lefkada, Greece. Four supercharged Sea-Doos (2026 fleet), a ten-minute safety briefing, and the best coves of the Ionian. Family-run by David &amp; Kristina Goldberg."
  themeColor="#071d30"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": "Ride the Ionian like a local — Jetski Lefkada Rentals",
    "description": "Premium Sea-Doo jetski experience on Lefkada, Greece. Family-run by Kristina & David Goldberg.",
    "thumbnailUrl": "https://images.unsplash.com/photo-1625194398019-62a5362c1e52?w=1200&q=80&auto=format&fit=crop",
    "uploadDate": "2026-01-01T00:00:00Z",
    "contentUrl": "https://assets.mixkit.co/videos/11943/11943-720.mp4",
    "embedUrl": "https://jetski-lefkada-rentals.com/"
  })} />

  <div class="v2">
    <Navbar2 />
    <Hero2 />
    <TrustMarquee2 />
    <Fleet2 />
    <HowItWorks2 />
    <Gallery2 />
    <Faq2 />
    <Booking2 />
    <CtaFinal2 />
    <Footer2 />
  </div>
</LayoutBare>
