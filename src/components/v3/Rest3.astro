---
import { testimonials } from "../../data/testimonials";
import type { Lang } from "../../i18n/translations";
import { getT } from "../../i18n/translations";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = getT(lang);

const galleryImages = [
  "https://images.unsplash.com/photo-1533106418989-88406c7cc8ca?w=1400&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1519046904884-53103b34b206?w=1400&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1504893524553-b855bce32c67?w=1400&q=85&auto=format&fit=crop",
  "https://images.unsplash.com/photo-1527631746610-bca00a040d60?w=1400&q=85&auto=format&fit=crop",
];
---

<!-- Scrolling marquee -->
<section class="relative py-12 overflow-hidden border-y" style="background: linear-gradient(90deg, rgba(10,6,20,0.9), rgba(20,10,34,0.9)); border-color: rgba(255,181,138,0.15);">
  <div class="v3-scroll-marquee">
    {
      [...Array(2)].flatMap(() =>
        ["Fully insured", "Open Daily", "4.9 stars", "327 reviews", "Since 2019", "5000+ rides", "Families & Groups", "Free cancel 48h", "Fastest on the island", "Licensed by Port Authority"].map((label) => (
          <div class="flex items-center gap-6 shrink-0">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="#ff2d87" aria-hidden="true"><circle cx="12" cy="12" r="6"/></svg>
            <span class="v3-display text-4xl lg:text-6xl" style="color: var(--v3-peach-100);">{label}</span>
          </div>
        ))
      )
    }
  </div>
</section>

<!-- How It Works -->
<section id="how" class="relative py-24 lg:py-40 overflow-hidden">
  <div class="v3-orb top-[20%] right-[10%] w-[500px] h-[500px]" style="background: #ff2d87;"></div>
  <div class="relative mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16 lg:mb-24">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.how.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          {t.how.h2Line1}<br /><em>{t.how.h2Line2}</em>
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {t.how.steps.map((step) => (
        <div
          class="relative p-8 lg:p-10 rounded-[1.5rem] overflow-hidden border transition-transform duration-500 hover:-translate-y-2"
          style="background: rgba(20,10,34,0.5); border-color: rgba(255,181,138,0.15); backdrop-filter: blur(12px);"
        >
          <div class="v3-display italic text-7xl mb-8" style="background: linear-gradient(135deg, #ff4420, #ff2d87); -webkit-background-clip: text; background-clip: text; color: transparent; font-weight: 200;">
            {step.n}
          </div>
          <h3 class="v3-display text-3xl mb-4">{step.t}</h3>
          <p class="text-sm lg:text-base leading-relaxed" style="color: rgba(255,230,212,0.7);">{step.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Gallery -->
<section class="relative py-24 lg:py-40 overflow-hidden">
  <div class="mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.gallery.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          <em>{t.gallery.h2Line1}</em><br />{t.gallery.h2Line2}
        </h2>
      </div>
    </div>
    <div class="grid grid-cols-12 gap-4 lg:gap-6">
      {t.gallery.stops.map((s, i) => {
        const spans = [
          "col-span-12 md:col-span-8 aspect-[16/9]",
          "col-span-12 md:col-span-4 aspect-[4/5]",
          "col-span-12 md:col-span-4 aspect-[4/5]",
          "col-span-12 md:col-span-8 aspect-[16/9]",
        ];
        return (
          <figure class:list={["group relative overflow-hidden rounded-[1.5rem]", spans[i]]}>
            <img
              src={galleryImages[i]}
              alt={s.t}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-[1.5s] group-hover:scale-110"
              style="filter: contrast(1.2) brightness(0.8) saturate(1.3) hue-rotate(-10deg);"
            />
            <div class="absolute inset-0 mix-blend-overlay opacity-70" style="background: linear-gradient(135deg, rgba(255,68,32,0.4), rgba(255,45,135,0.3));"></div>
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(10,6,20,0.95) 0%, transparent 50%);"></div>
            <figcaption class="absolute bottom-0 left-0 right-0 p-8 lg:p-10">
              <div class="v3-display italic text-4xl mb-1">{String(i + 1).padStart(2, "0")}</div>
              <h3 class="v3-display text-3xl lg:text-5xl mb-2">{s.t}</h3>
              <p class="text-sm" style="color: var(--v3-peach-300);">{s.c}</p>
            </figcaption>
          </figure>
        );
      })}
    </div>
  </div>
</section>

<!-- Testimonials -->
<section id="voices" class="relative py-24 lg:py-40 overflow-hidden">
  <div class="v3-orb bottom-[10%] left-[10%] w-[600px] h-[600px]" style="background: #8a4fff;"></div>
  <div class="relative mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16 lg:mb-20">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.voices.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          {t.voices.h2Line1}<br /><em>{t.voices.h2Line2}</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-3 flex items-end">
        <div>
          <div class="v3-display italic text-8xl" style="background: linear-gradient(135deg, #ff4420, #ff2d87, #ffd76a); -webkit-background-clip: text; background-clip: text; color: transparent;">4.9</div>
          <div class="font-mono text-[10px] uppercase tracking-[0.2em] mt-2" style="color: var(--v3-peach-300);">{t.voices.ratingSource}</div>
        </div>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {testimonials.map((tv, i) => (
        <article
          class:list={["p-8 lg:p-10 rounded-[1.5rem] border", i === 0 && "lg:row-span-2"]}
          style="background: rgba(20,10,34,0.4); border-color: rgba(255,181,138,0.15); backdrop-filter: blur(12px);"
        >
          <div class="flex items-center gap-1 mb-6">
            {Array.from({ length: tv.rating }).map(() => (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#ff4420" aria-hidden="true">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <blockquote class="v3-display text-2xl lg:text-3xl leading-tight mb-8">"{tv.quote}"</blockquote>
          <footer class="pt-6 border-t flex items-center justify-between" style="border-color: rgba(255,230,212,0.15);">
            <div>
              <div class="font-body text-sm font-medium" style="color: var(--v3-peach-100);">{tv.author}</div>
              <div class="font-mono text-[10px] uppercase tracking-[0.14em] mt-1" style="color: var(--v3-peach-300);">{tv.origin}</div>
            </div>
            <div class="font-mono text-[9px] uppercase tracking-[0.2em]" style="color: var(--v3-flame-500);">{tv.source}</div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="relative py-24 lg:py-40">
  <div class="mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.faq.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          {t.faq.h2Line1}<br /><em>{t.faq.h2Line2}</em>
        </h2>
      </div>
    </div>
    <div class="max-w-4xl">
      {t.faq.items.map((f, i) => (
        <details class="group border-b" style="border-color: rgba(255,181,138,0.2);">
          <summary class="cursor-pointer list-none py-7 flex items-start justify-between gap-8 transition-opacity hover:opacity-80">
            <div class="flex items-start gap-6">
              <span class="font-display italic text-xl" style="background: linear-gradient(135deg, #ff4420, #ff2d87); -webkit-background-clip: text; background-clip: text; color: transparent;">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="v3-display text-xl lg:text-3xl leading-tight">{f.q}</h3>
            </div>
            <span class="shrink-0 w-10 h-10 rounded-full flex items-center justify-center group-open:rotate-45 transition-transform duration-500" style="background: linear-gradient(135deg, #ff4420, #ff2d87); color: #0a0614;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
            </span>
          </summary>
          <div class="pb-8 pl-12">
            <p class="text-base lg:text-lg leading-relaxed max-w-3xl" style="color: rgba(255,230,212,0.75);">{f.a}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- Final CTA -->
<section class="relative py-24 lg:py-40 overflow-hidden">
  <div class="v3-orb top-[10%] left-1/2 -translate-x-1/2 w-[900px] h-[900px]" style="background: #ff4420;"></div>
  <div class="v3-orb bottom-[10%] left-1/2 -translate-x-1/2 w-[700px] h-[700px]" style="background: #ff2d87; animation-delay: -8s;"></div>
  <div class="relative mx-auto max-w-[1400px] px-6 lg:px-12 text-center">
    <div class="v3-eyebrow inline-flex mb-10"><span>{t.cta.eyebrow}</span></div>
    <h2 class="v3-display text-6xl lg:text-[clamp(5rem,12vw,14rem)] max-w-[14ch] mx-auto">
      <em>{t.cta.h2}</em>
    </h2>
    <p class="mt-12 max-w-xl mx-auto text-lg lg:text-xl italic font-display" style="color: var(--v3-peach-300);">{t.cta.desc}</p>
    <div class="mt-14 flex flex-wrap items-center justify-center gap-4">
      <a href="#book" class="v3-btn" data-cro="v3-final-primary">
        {t.cta.btn}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
      </a>
      <a href="https://wa.me/306955612777" target="_blank" rel="noopener" class="v3-btn-outline">{t.cta.dm}</a>
    </div>
    <div class="mt-16 pt-8 border-t flex flex-wrap items-center justify-center gap-8 font-mono text-[10px] uppercase tracking-[0.2em]" style="border-color: rgba(255,181,138,0.2); color: rgba(255,230,212,0.6);">
      <span>{t.cta.cancel}</span>
      <span>{t.cta.deposit}</span>
      <span>{t.cta.confirm}</span>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative py-16 border-t" style="border-color: rgba(255,181,138,0.15);">
  <div class="mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-8">
      <div class="col-span-12 lg:col-span-5">
        <div class="flex items-center gap-3 mb-6">
          <span class="v3-display italic text-3xl" style="background: linear-gradient(135deg, #ff4420, #ff2d87); -webkit-background-clip: text; background-clip: text; color: transparent;">Jetski Lefkada</span>
        </div>
        <p class="max-w-md text-sm leading-relaxed" style="color: rgba(255,230,212,0.6);">{t.footer.tagline}</p>
        <div class="mt-6 space-y-2">
          <a href="tel:+306955612777" class="block font-mono text-[11px] uppercase tracking-[0.18em]" style="color: var(--v3-peach-300);">+30 695 561 2777</a>
          <a href="mailto:info@jetski-lefkada-rentals.com" class="block font-mono text-[11px] uppercase tracking-[0.18em]" style="color: var(--v3-peach-300);">info@jetski-lefkada-rentals.com</a>
        </div>
      </div>

      <div class="col-span-6 lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] mb-4" style="color: var(--v3-flame-500);">{t.footer.exploreLabel}</div>
        <ul class="space-y-2 font-body text-sm" style="color: var(--v3-peach-300);">
          <li><a href="#fleet" class="hover:opacity-80 transition-opacity">{t.footer.links.fleet}</a></li>
          <li><a href="#how" class="hover:opacity-80 transition-opacity">{t.footer.links.how}</a></li>
          <li><a href="#voices" class="hover:opacity-80 transition-opacity">{t.footer.links.voices}</a></li>
          <li><a href="#faq" class="hover:opacity-80 transition-opacity">{t.footer.links.faq}</a></li>
        </ul>
      </div>

      <div class="col-span-6 lg:col-span-2">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] mb-4" style="color: var(--v3-flame-500);">{t.footer.followLabel}</div>
        <ul class="space-y-2 font-body text-sm mb-5" style="color: var(--v3-peach-300);">
          <li>
            <a href="https://www.instagram.com/jetski__lefkada/" target="_blank" rel="noopener" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              @jetski__lefkada
            </a>
          </li>
          <li><a href="/imprint" class="hover:opacity-80 transition-opacity">{t.footer.links.imprint}</a></li>
          <li><a href="/privacy" class="hover:opacity-80 transition-opacity">{t.footer.links.privacy}</a></li>
          <li><a href="/terms" class="hover:opacity-80 transition-opacity">{t.footer.links.terms}</a></li>
        </ul>
        <!-- Instagram QR code -->
        <a href="https://www.instagram.com/jetski__lefkada/" target="_blank" rel="noopener" class="block w-24 opacity-70 hover:opacity-100 transition-opacity" aria-label="Follow @jetski__lefkada on Instagram">
          <img src="/instagram-qr.png" alt="Instagram QR @jetski__lefkada" width="96" height="96" class="rounded-lg" />
        </a>
      </div>

      <div class="col-span-12 lg:col-span-3">
        <div class="font-mono text-[10px] uppercase tracking-[0.2em] mb-4" style="color: var(--v3-flame-500);">{t.footer.hoursLabel}</div>
        <div class="space-y-2 text-sm" style="color: var(--v3-peach-100);">
          <div class="flex justify-between"><span>{t.footer.morning}</span><span style="color: var(--v3-peach-300);">{t.footer.morningTime}</span></div>
          <div class="flex justify-between"><span>{t.footer.afternoon}</span><span style="color: var(--v3-peach-300);">{t.footer.afternoonTime}</span></div>
          <div class="flex justify-between pt-2 mt-2 border-t" style="border-color: rgba(255,181,138,0.15);"><span>{t.footer.season}</span><span style="color: var(--v3-peach-300);">{t.footer.seasonTime}</span></div>
        </div>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t flex flex-wrap items-center justify-between gap-4 font-mono text-[10px] uppercase tracking-[0.2em]" style="border-color: rgba(255,181,138,0.15); color: rgba(255,230,212,0.5);">
      <div>{t.footer.copyright}</div>
      <div>{t.footer.builtBy} <a href="https://nobrainer-ai.at" class="hover:underline" style="color: var(--v3-flame-500);">Nobrainer AI</a></div>
    </div>
  </div>
</footer>
