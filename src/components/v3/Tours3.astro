---
import { tours } from "../../data/tours";
import type { Lang } from "../../i18n/translations";
import { getT } from "../../i18n/translations";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = getT(lang);
---

<section id="tours" class="relative py-24 lg:py-40 overflow-hidden">
  <div class="v3-orb top-[15%] left-[5%] w-[500px] h-[500px]" style="background: #1a6fa8; opacity: 0.6;"></div>
  <div class="relative mx-auto max-w-[1700px] px-6 lg:px-12">

    <!-- Section header -->
    <div class="grid grid-cols-12 gap-6 mb-16 lg:mb-24">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.tours.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          {t.tours.h2Line1}<br /><em>{t.tours.h2Line2}</em>
        </h2>
      </div>
      <div class="col-span-12 lg:col-span-3 flex lg:items-end lg:justify-end">
        <div class="flex flex-wrap gap-3">
          <span class="font-mono text-[10px] uppercase tracking-[0.18em] px-3 py-1.5 rounded-full border" style="border-color: rgba(255,181,138,0.3); color: rgba(255,230,212,0.6);">
            {t.tours.noLicense}
          </span>
        </div>
      </div>
    </div>

    <!-- Tour cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {tours.map((tour) => (
        <article
          class="relative p-8 lg:p-12 rounded-[1.5rem] border overflow-hidden transition-transform duration-500 hover:-translate-y-1"
          style="background: rgba(20,10,34,0.5); border-color: rgba(255,181,138,0.15); backdrop-filter: blur(12px);"
        >
          <!-- Duration + guide badge row -->
          <div class="flex items-center gap-3 mb-8 flex-wrap">
            <span
              class="font-mono text-[11px] uppercase tracking-[0.22em] px-3 py-1.5 rounded-full border"
              style={`border-color: ${tour.accent}40; color: ${tour.accent}; background: ${tour.accent}15;`}
            >
              {tour.durationMin} min
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.16em]" style="color: rgba(255,230,212,0.45);">
              {t.tours.withGuide}
            </span>
          </div>

          <!-- Name -->
          <h3 class="v3-display text-4xl lg:text-5xl mb-3">{tour.name}</h3>
          <p class="font-display italic text-xl mb-8" style="color: rgba(255,230,212,0.55);">{tour.tagline}</p>

          <!-- Description -->
          <p class="text-base leading-relaxed mb-10" style="color: rgba(255,230,212,0.75);">{tour.description}</p>

          <!-- Highlights -->
          <ul class="space-y-3 mb-10">
            {tour.highlights.map((h) => (
              <li class="flex items-start gap-3">
                <svg
                  width="16" height="16" viewBox="0 0 24 24"
                  fill="none" stroke={tour.accent} stroke-width="2.5"
                  class="mt-0.5 shrink-0" aria-hidden="true"
                >
                  <path d="M20 6L9 17l-5-5"/>
                </svg>
                <span class="text-sm leading-relaxed" style="color: rgba(255,230,212,0.85);">{h}</span>
              </li>
            ))}
          </ul>

          <!-- Perfect for tags -->
          <div class="mb-10">
            <p class="font-mono text-[10px] uppercase tracking-[0.2em] mb-3" style="color: rgba(255,230,212,0.4);">
              {t.tours.perfectFor}
            </p>
            <div class="flex flex-wrap gap-2">
              {tour.forWho.map((tag) => (
                <span
                  class="font-mono text-[10px] uppercase tracking-[0.14em] px-2.5 py-1 rounded"
                  style="background: rgba(255,181,138,0.08); color: rgba(255,230,212,0.65); border: 1px solid rgba(255,181,138,0.12);"
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- CTA -->
          <div class="space-y-2">
            <a
              href="https://wa.me/306955612777"
              target="_blank"
              rel="noopener"
              class="v3-btn w-full justify-center"
              data-cro="tours-whatsapp"
            >
              {t.tours.ctaBtn}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </a>
            <p class="text-center font-mono text-[10px] uppercase tracking-[0.16em]" style="color: rgba(255,230,212,0.35);">
              {t.tours.priceLabel}
            </p>
          </div>

          <!-- Accent bottom border -->
          <div
            class="absolute bottom-0 left-0 right-0 h-[2px] rounded-b-[1.5rem]"
            style={`background: linear-gradient(90deg, ${tour.accent}, transparent);`}
          ></div>
        </article>
      ))}
    </div>
  </div>
</section>
