---
import type { Lang } from "../../i18n/translations";
import { getT } from "../../i18n/translations";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = getT(lang);

const links = [
  { href: "#fleet", label: t.nav.fleet },
  { href: "#tours", label: t.nav.tours },
  { href: "#how", label: t.nav.how },
  { href: "#voices", label: t.nav.voices },
  { href: "#faq", label: t.nav.faq },
  { href: "#book", label: t.nav.book },
];
---

<nav class="absolute top-0 left-0 right-0 z-40 pointer-events-none pt-20 lg:pt-24">
  <div class="pointer-events-auto mx-auto max-w-[1700px] px-6 lg:px-12 flex items-center justify-between">
    <a href="/" class="group flex items-center gap-3" aria-label="Jetski Lefkada Rentals home">
      <span class="font-display italic text-3xl leading-none" style="background: linear-gradient(135deg, #ff4420, #ff2d87); -webkit-background-clip: text; background-clip: text; color: transparent;">Jetski</span>
      <span class="font-mono text-[10px] uppercase tracking-[0.22em]" style="color: var(--v3-peach-300);">Lefkada / GR</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="font-mono text-[11px] uppercase tracking-[0.22em] relative group"
            style="color: var(--v3-peach-300);"
          >
            {l.label}
            <span
              class="absolute -bottom-2 left-0 right-0 h-px scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-500"
              style="background: linear-gradient(90deg, #ff4420, #ff2d87);"
            />
          </a>
        ))
      }
    </div>

    <a href="#book" class="v3-btn !py-3 !px-5 !text-xs">
      {t.nav.reserve}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</nav>
