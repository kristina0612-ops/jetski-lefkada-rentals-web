---
import { jetskis } from "../../data/jetskis";
import type { Lang } from "../../i18n/translations";
import { getT } from "../../i18n/translations";

interface Props {
  lang?: Lang;
}
const { lang = "en" } = Astro.props;
const t = getT(lang);

const durations = {
  en: ["10 minutes", "20 minutes", "30 minutes", "1 hour", "2 hours", "Half day (4h)", "Full day (8h)"],
  de: ["10 Minuten", "20 Minuten", "30 Minuten", "1 Stunde", "2 Stunden", "Halber Tag (4h)", "Ganzer Tag (8h)"],
  el: ["10 λεπτά", "20 λεπτά", "30 λεπτά", "1 ώρα", "2 ώρες", "Μισή μέρα (4ω)", "Ολόκληρη μέρα (8ω)"],
};
const durationOptions = durations[lang] ?? durations.en;
---

<section id="book" class="relative py-24 lg:py-40 overflow-hidden">
  <div class="v3-orb top-[10%] right-[10%] w-[500px] h-[500px]" style="background: #ff4420; opacity: 0.15;"></div>
  <div class="v3-orb bottom-[10%] left-[5%] w-[400px] h-[400px]" style="background: #8a4fff; opacity: 0.15;"></div>

  <div class="relative mx-auto max-w-[1700px] px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-6 mb-16">
      <div class="col-span-12 lg:col-span-9">
        <div class="v3-eyebrow mb-6"><span>{t.form.eyebrow}</span></div>
        <h2 class="v3-display text-5xl lg:text-[clamp(4rem,8vw,9rem)]">
          {t.form.h2Line1}<br /><em>{t.form.h2Line2}</em>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <!-- Left: info -->
      <div class="lg:col-span-4 flex flex-col gap-5">
        {[t.form.infoResponse, t.form.infoCancel, t.form.infoDeposit, t.form.infoMeeting].map((item, i) => (
          <div class="flex items-start gap-4 p-6 rounded-[1rem] border" style="background: rgba(20,10,34,0.4); border-color: rgba(255,181,138,0.15);">
            <span class="text-2xl shrink-0">{["⚡", "📅", "💳", "📍"][i]}</span>
            <div>
              <div class="font-mono text-[10px] uppercase tracking-[0.18em] mb-1" style="color: var(--v3-peach-300);">{item.label}</div>
              <div class="v3-display text-2xl">{item.value}</div>
            </div>
          </div>
        ))}
        <div class="p-6 rounded-[1rem] border" style="background: rgba(20,10,34,0.4); border-color: rgba(255,181,138,0.15);">
          <div class="font-mono text-[10px] uppercase tracking-[0.18em] mb-3" style="color: var(--v3-flame-500);">{t.form.whatsappLabel}</div>
          <a href="https://wa.me/306955612777?text=Hi%2C%20I%27d%20like%20to%20book%20a%20jetski%20on%20Lefkada" target="_blank" rel="noopener" class="v3-btn-outline inline-flex">
            {t.form.whatsappBtn}
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <div class="lg:col-span-8">
        <form
          action="https://formsubmit.co/info@jetski-lefkada-rentals.com"
          method="POST"
          id="booking-form"
          class="space-y-5"
        >
          <input type="text" name="_honey" style="display:none" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_subject" value="New jetski booking inquiry — Lefkada" />
          <input type="hidden" name="_next" value="https://jetski-lefkada-rentals.com/?booked=1" />
          <input type="hidden" name="_lang" value={lang} />

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div class="space-y-2">
              <label class="bf-label" for="name">{t.form.labelName}</label>
              <input id="name" type="text" name="name" required autocomplete="name" placeholder={t.form.placeholderName} class="bf-input" />
            </div>
            <div class="space-y-2">
              <label class="bf-label" for="phone">{t.form.labelPhone}</label>
              <input id="phone" type="tel" name="phone" required autocomplete="tel" placeholder={t.form.placeholderPhone} class="bf-input" />
            </div>
            <div class="space-y-2">
              <label class="bf-label" for="date">{t.form.labelDate}</label>
              <input id="date" type="date" name="date" required class="bf-input" />
            </div>
            <div class="space-y-2">
              <label class="bf-label" for="duration">{t.form.labelDuration}</label>
              <select id="duration" name="duration" class="bf-input">
                {durationOptions.map((d, i) => (
                  <option value={d} selected={i === 6}>{d}</option>
                ))}
              </select>
            </div>
          </div>

          <div class="space-y-2">
            <label class="bf-label" for="jetski">{t.form.labelJetski}</label>
            <select id="jetski" name="jetski" class="bf-input">
              <option value="No preference">{t.form.noPreference}</option>
              {jetskis.map((js) => (
                <option value={`${js.name} – ${js.brand} ${js.model}`}>
                  {js.name} — {js.brand} {js.model} · €{js.pricePerHour}/hr
                </option>
              ))}
            </select>
          </div>

          <div class="space-y-2">
            <label class="bf-label" for="message">{t.form.labelMessage}</label>
            <textarea id="message" name="message" rows="3" placeholder={t.form.placeholderMessage} class="bf-input resize-none"></textarea>
          </div>

          <div class="pt-2">
            <button type="submit" id="submit-btn" class="v3-btn w-full md:w-auto">
              {t.form.submitBtn}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </button>
          </div>

          <div id="form-success" class="hidden p-6 rounded-[1rem] border text-center" style="background: rgba(20,10,34,0.6); border-color: rgba(255,68,32,0.4);">
            <div class="v3-display italic text-3xl mb-2" style="background: linear-gradient(135deg, #ff4420, #ff2d87); -webkit-background-clip: text; background-clip: text; color: transparent;">
              {t.form.successTitle}
            </div>
            <p class="text-sm" style="color: var(--v3-peach-300);">{t.form.successDesc}</p>
          </div>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .bf-label {
    display: block;
    font-family: "JetBrains Mono", ui-monospace, monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--v3-peach-300);
  }
  .bf-input {
    display: block;
    width: 100%;
    padding: 0.875rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(255, 181, 138, 0.2);
    background: rgba(20, 10, 34, 0.5);
    color: var(--v3-peach-100);
    font-family: "Instrument Sans", ui-sans-serif, system-ui, sans-serif;
    font-size: 0.9375rem;
    transition: border-color 0.3s ease, background 0.3s ease;
    backdrop-filter: blur(8px);
    -webkit-appearance: none;
  }
  .bf-input::placeholder { color: rgba(255, 230, 212, 0.35); }
  .bf-input:focus { outline: none; border-color: #ff4420; background: rgba(20, 10, 34, 0.8); }
  select.bf-input option { background: #140a22; color: #ffe6d4; }
</style>

<script>
  const form = document.getElementById("booking-form") as HTMLFormElement | null;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement | null;
  const success = document.getElementById("form-success");
  if (window.location.search.includes("booked=1") && success) {
    success.classList.remove("hidden");
    form?.classList.add("hidden");
  }
  form?.addEventListener("submit", () => {
    if (btn) { btn.disabled = true; }
  });
</script>
